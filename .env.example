# Google Gemini API key used for signature verification requests.
GEMINI_API_KEY=your_gemini_api_key_here

# Secret salt used with machine identity to derive encryption keys.
APP_SECRET_SALT=signverifypro_unique_salt_2024

# Application licence tier controlling feature availability.
LICENCE_TIER=FREE

# Semantic version shown in the app UI and metadata.
APP_VERSION=1.0.0

# SQLite database filename or absolute path.
DB_PATH=signverify.db

# Directory name under app data for persisted signature files.
SIGNATURES_DIR=signatures

# Logging verbosity level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
